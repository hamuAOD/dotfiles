# command = /bin/zsh -c "tmux a -t Ghostty || tmux new -s Ghostty"
confirm-close-surface = false

font-family = "Firple"
font-family = "HackGen35 Console NF"
font-family = "UDEV Gothic 35NFLG"

font-style = bold
font-size = 13
font-thicken = true
font-thicken-strength = 70
font-style-italic = false
font-style-bold-italic = false

alpha-blending = native
# 日本語文字化け対策
font-feature = -dlig

theme = dracula2
adjust-cell-width = 2%
adjust-cell-height = 4%
background-opacity = 0.90
background-blur = true
unfocused-split-opacity = 0.6
unfocused-split-fill = #101010
macos-titlebar-style = tabs

window-padding-x = 10
window-padding-y = 10
window-padding-balance = false
window-padding-color = background
window-height = 50
window-width = 130
window-position-x = 60
window-position-y = 60
# etc
# term = xterm-256color
term = xterm-ghostty
shell-integration-features = sudo

### Keybind
keybind = super+o=write_screen_file:open
keybind = super+i=write_screen_file:paste
keybind = ctrl+shift+;>t=toggle_quick_terminal
# Keybind: Tab
keybind = ctrl+shift+;>c=new_tab
keybind = ctrl+shift+;>x=close_surface
keybind = ctrl+shift+;>f=next_tab
keybind = ctrl+shift+;>b=previous_tab
# Keybind: Pane
keybind = ctrl+shift+;>v=new_split:right
keybind = ctrl+shift+;>s=new_split:down
keybind = ctrl+shift+;>a=new_split:down
keybind = ctrl+shift+;>j=goto_split:bottom
keybind = ctrl+shift+;>k=goto_split:top
keybind = ctrl+shift+;>h=goto_split:left
keybind = ctrl+shift+;>l=goto_split:right
keybind = ctrl+shift+;>down=goto_split:bottom
keybind = ctrl+shift+;>up=goto_split:top
keybind = ctrl+shift+;>left=goto_split:left
keybind = ctrl+shift+;>right=goto_split:right
keybind = ctrl+shift+;>p=goto_split:previous
keybind = ctrl+shift+;>n=goto_split:next
keybind = super+down=resize_split:down,30
keybind = super+up=resize_split:up,30
keybind = super+left=resize_split:left,30
keybind = super+right=resize_split:right,30
keybind = ctrl+shift+;>e=equalize_splits
keybind = ctrl+shift+;>z=toggle_split_zoom
# Page Scroll
# keybind = ctrl+shift+;>b=scroll_page_up
# keybind = ctrl+shift+;>f=scroll_page_down
# Key-Text
keybind = alt+left=text:\x1bb
keybind = alt+right=text:\x1bf
# Other
keybind = shift+enter=text:\n # Shift+Enterで改行
keybind = cmd+k=clear_screen
keybind = ctrl+shift+;>shift+f=reset_font_size
keybind = ctrl+shift+;>r=reload_config
copy-on-select = clipboard
